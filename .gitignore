# =============================================================================
# sine-one .gitignore
# Covers: Rust/Cargo, nih-plug/CLAP, VS Code, macOS
# =============================================================================


# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------

# Build output
/target/
**/target/

# Cargo lock is committed for binaries; for libraries it's typically omitted.
# This is a plugin (cdylib) — treat it as a binary and keep Cargo.lock.
# Cargo.lock

# Generated by cargo-vendor
/vendor/

# Backup files generated by rustfmt
**/*.rs.bk

# LLVM profiling data (cargo-llvm-cov, cargo-fuzz)
**/*.profraw
**/*.profdata

# cargo-fuzz artifacts
fuzz/artifacts/
fuzz/corpus/
fuzz/coverage/


# -----------------------------------------------------------------------------
# nih-plug / CLAP plugin build artifacts
# -----------------------------------------------------------------------------

# Bundled plugin output (produced by `cargo xtask bundle`)
/target/bundled/

# VST3 build artifacts (not used in this project, but guard against accidental generation)
**/*.vst3

# Standalone binary output (not the source; the binary itself)
# (already covered by /target/, but explicit for clarity)


# -----------------------------------------------------------------------------
# criterion benchmark artifacts
# -----------------------------------------------------------------------------

# HTML reports and baseline data generated by `cargo bench`
/criterion/
**/criterion/


# -----------------------------------------------------------------------------
# cargo tools
# -----------------------------------------------------------------------------

# cargo-audit vulnerability database cache
/.cargo/advisory-db/

# cargo-deny cache
/.cargo/deny/


# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------

.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# History and workspace state
.history/
*.vsix

# Local workspace file (user-specific, not project config)
*.code-workspace


# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------

# Finder metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Thumbnail cache
__MACOSX/

# AppleDouble resource forks
**/.AppleDouble

# Quarantine extended attributes (set by Gatekeeper on downloaded files)
# These should never be committed — clear with: xattr -d com.apple.quarantine <file>
# (no filename pattern; xattr data is stored in the filesystem, not as a file)

# Time Machine exclusion markers
.fseventsd/

# macOS icon customization
Icon?


# -----------------------------------------------------------------------------
# Editor temporaries and OS noise
# -----------------------------------------------------------------------------

# Swap / backup files
*~
*.swp
*.swo
*.tmp
*.bak
*.orig

# Patch files
*.patch
*.diff

# Lock files for editors other than Cargo.lock
.editorconfig.lock


# -----------------------------------------------------------------------------
# Environment and secrets
# -----------------------------------------------------------------------------

.env
.env.*
!.env.example
*.pem
*.key
*.p12
